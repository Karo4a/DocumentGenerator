@inherits LayoutComponentBase
@using DocumentGenerator.Web.Services
@inject UserStateInitializer UserStateInitializer

<NavMenu />

<main>
    <article class="content px-4">
        @Body
    </article>
</main>

<Toasts class="p-3" AutoHide="true" Delay="3000" Placement="ToastsPlacement.TopRight" />

@code {
    protected override async Task OnInitializedAsync()
    {
        await UserStateInitializer.InitializeAsync();
    }
}

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>