@page "/products"
@using DocumentGenerator.Api.Models.Product
@using DocumentGenerator.Web.Models
@using DocumentGenerator.Web.Services.Product

@inject IJSRuntime JS
@inject IProductService ProductService
@inject ToastService ToastService

<PageTitle>Товары</PageTitle>

<h3>Товары</h3>

@if (isLoading)
{
    <Spinner />
}
else
{
    <Button Color="ButtonColor.Success" @onclick="ShowCreateModal">+ Добавить товар</Button>

    @if (products is null || products.Length == 0)
    {
        <p class="mt-3">Нет товаров</p>
    }
    else
    {
        <table class="table table-hover mt-3">
            <thead>
                <tr>
                    <th>Наименование</th>
                    <th>Стоимость</th>
                    <th style="width: 140px;">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in products)
                {
                    <tr>
                        <td>@product.Name</td>
                        <td>@product.Cost.ToString("C")</td>
                        <td>
                            <Dropdown Color="DropdownColor.Secondary">
                                <DropdownToggleButton>Действия</DropdownToggleButton>
                                <DropdownMenu>
                                    <DropdownItem @onclick="() => ShowEditModal(product)">
                                        <Button Size="ButtonSize.Small" Color="ButtonColor.Primary" @onclick="() => ShowEditModal(product)">Редактировать</Button>
                                    </DropdownItem>
                                    <DropdownItem @onclick="() => DeleteProduct(product.Id)">
                                        <Button Size="ButtonSize.Small" Color="ButtonColor.Danger" @onclick="() => DeleteProduct(product.Id)">Удалить</Button>
                                    </DropdownItem>
                                </DropdownMenu>
                            </Dropdown>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<Modal @ref="modal" Title="@(isEditMode ? "Редактировать товар" : "Добавить товар")">
    <BodyTemplate>
        <div class="mb-3">
            <label class="form-label">Наименование</label>
            <TextInput @bind-Value="currentModel.Name" Placeholder="Введите наименование" />
        </div>
        <div class="mb-3">
            <label class="form-label">Стоимость</label>
            <NumberInput @bind-Value="currentModel.Cost" Step="0.01" />
        </div>
    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Secondary" @onclick="HideModal">Отмена</Button>
        <Button Color="ButtonColor.Primary" @onclick="SaveProduct">Сохранить</Button>
    </FooterTemplate>
</Modal>

@code {
    private ProductApiModel[]? products;
    private bool isLoading = true;
    private Modal modal = new();
    private bool isEditMode;
    private ProductRequestApiModel currentModel = new();
    private Guid editingId;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        isLoading = true;
        StateHasChanged();

        var result = await ProductService.GetAllAsync();

        if (result.IsSuccess)
        {
            products = result.Value;
        }
        else
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка загрузки", result.ErrorMessage ?? "Неизвестная ошибка"));
        }

        isLoading = false;
        StateHasChanged();
    }

    private async Task ShowCreateModal()
    {
        isEditMode = false;
        currentModel = new();
        await modal.ShowAsync();
    }

    private async Task ShowEditModal(ProductApiModel product)
    {
        isEditMode = true;
        editingId = product.Id;
        currentModel = new ProductRequestApiModel
        {
            Name = product.Name,
            Cost = product.Cost
        };
        await modal.ShowAsync();
    }

    private async Task SaveProduct()
    {
        Result<ProductApiModel> saveResult;

        if (isEditMode)
        {
            saveResult = await ProductService.UpdateAsync(editingId, currentModel);
        }
        else
        {
            saveResult = await ProductService.CreateAsync(currentModel);
        }

        if (saveResult.IsSuccess)
        {
            await LoadProducts();
            await modal.HideAsync();
        }
        else
        {
            var toastType = saveResult.StatusCode == 409 ? ToastType.Warning : ToastType.Danger;
            ToastService.Notify(new(toastType, "Ошибка сохранения", saveResult.ErrorMessage ?? "Неизвестная ошибка"));
        }
    }

    private async Task DeleteProduct(Guid id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Удалить товар?");
        if (!confirmed) return;

        var result = await ProductService.DeleteAsync(id);

        if (result.IsSuccess)
        {
            await LoadProducts();
        }
        else
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка удаления", result.ErrorMessage ?? "Неизвестная ошибка"));
        }
    }

    private async Task HideModal() => await modal.HideAsync();
}