@page "/users"
@using DocumentGenerator.Api.Client
@using DocumentGenerator.Web.Services

@inject IDocumentGeneratorApiClient ApiClient
@inject UserState UserState
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ToastService ToastService

<PageTitle>Пользователи</PageTitle>

<h3>Управление пользователями</h3>

@if (isLoading)
{
    <Spinner />
}
else
{
    @if (users is null || users.Length == 0)
    {
        <p class="mt-3">Нет пользователей</p>
    }
    else
    {
        <table class="table table-hover mt-3">
            <thead>
                <tr>
                    <th>Логин</th>
                    <th>Email</th>
                    <th>Роль</th>
                    <th style="width: 200px;">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users)
                {
                    var isSelf = user.Id == UserState.Id;
                    <tr class="@(isSelf ? "table-active" : "")">
                        <td>@user.Login @(isSelf ? "(это вы)" : "")</td>
                        <td>@user.Email</td>
                        <td>@GetRoleDisplay(user.Role)</td>
                        <td>
                            @if (!isSelf)
                            {
                                <Button Color="ButtonColor.Primary" @onclick="() => OpenRoleModal(user)">Роль</Button>
                                <Button Color="ButtonColor.Danger" @onclick="() => DeleteUser(user)">Удалить</Button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<Modal @ref="roleModal" Title="@($"Смена роли: {selectedUser?.Login}")">
    <BodyTemplate>
        <div class="mb-3">
            <label class="form-label">Новая роль</label>
            <select class="form-select" @bind="selectedRole">
                @foreach (var role in Enum.GetValues<UserRoleApi>())
                {
                    <option value="@role">@GetRoleDisplay(role)</option>
                }
            </select>
        </div>
    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Secondary" @onclick="CloseRoleModal">Отмена</Button>
        <Button Color="ButtonColor.Primary" @onclick="SaveRoleAsync">Сохранить</Button>
    </FooterTemplate>
</Modal>

@code {
    private UserApiModel[]? users;
    private bool isLoading = true;
    private Modal roleModal = new();
    private UserApiModel? selectedUser;
    private UserRoleApi selectedRole;

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsAuthenticated || !UserState.IsAdmin)
        {
            Navigation.NavigateTo("/");
            return;
        }

        try
        {
            var list = await ApiClient.UserAllAsync();
            users = list is not null ? [.. list] : null;
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось загрузить пользователей"));
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OpenRoleModal(UserApiModel user)
    {
        selectedUser = user;
        selectedRole = user.Role;
        await roleModal.ShowAsync();
    }

    private async Task CloseRoleModal()
    {
        await roleModal.HideAsync();
        selectedUser = null;
    }

    private async Task SaveRoleAsync()
    {
        if (selectedUser is null) return;

        try
        {
            var request = new UserRoleRequestApiModel { Role = selectedRole };
            await ApiClient.UserChangeRoleAsync(selectedUser.Id, request);
            ToastService.Notify(new(ToastType.Success, "Успех", $"Роль пользователя {selectedUser.Login} изменена"));

            await CloseRoleModal();
            await ReloadUsersAsync();
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось изменить роль"));
        }
    }

    private async Task DeleteUser(UserApiModel user)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Удалить пользователя \"{user.Login}\"?");
        if (!confirmed) return;

        try
        {
            await ApiClient.UserDELETEAsync(user.Id);
            ToastService.Notify(new(ToastType.Success, "Успех", $"Пользователь {user.Login} удалён"));
            await ReloadUsersAsync();
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось удалить пользователя"));
        }
    }

    private async Task ReloadUsersAsync()
    {
        try
        {
            var list = await ApiClient.UserAllAsync();
            users = list is not null ? [.. list] : null;
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось загрузить пользователей"));
        }
    }

    private static string GetRoleDisplay(UserRoleApi role) => role switch
    {
        UserRoleApi.Viewer => "Просмотр",
        UserRoleApi.Editor => "Редактор",
        UserRoleApi.Admin => "Администратор",
        _ => role.ToString()
    };
}
