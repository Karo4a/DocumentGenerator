@page "/products"
@using DocumentGenerator.Api.Models.Product

@inject IJSRuntime JS
@inject ToastService ToastService

<PageTitle>Товары</PageTitle>

<h3>Товары</h3>

@if (isLoading)
{
    <Spinner />
}
else
{
    <Button Color="ButtonColor.Success" @onclick="ShowCreateModal">+ Добавить товар</Button>

    @if (products is null || products.Length == 0)
    {
        <p class="mt-3">Нет товаров</p>
    }
    else
    {
        <table class="table table-hover mt-3">
            <thead>
                <tr>
                    <th>Наименование</th>
                    <th>Стоимость</th>
                    <th style="width: 140px;">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in products)
                {
                    <tr>
                        <td>@product.Name</td>
                        <td>@product.Cost.ToString("C")</td>
                        <td>
                            <Dropdown Color="DropdownColor.Secondary">
                                <DropdownToggleButton>Действия</DropdownToggleButton>
                                <DropdownMenu>
                                    <DropdownItem @onclick="() => { }">
                                        <Button Size="ButtonSize.Small" Color="ButtonColor.Primary" @onclick="() => { }">Редактировать</Button>
                                    </DropdownItem>
                                    <DropdownItem @onclick="() => { }">
                                        <Button Size="ButtonSize.Small" Color="ButtonColor.Danger" @onclick="() => { }">Удалить</Button>
                                    </DropdownItem>
                                </DropdownMenu>
                            </Dropdown>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<Modal @ref="modal" Title="@(isEditMode ? "Редактировать товар" : "Добавить товар")">
    <BodyTemplate>
        <div class="mb-3">
            <label class="form-label">Наименование</label>
            <TextInput @bind-Value="currentModel.Name" Placeholder="Введите наименование" />
        </div>
        <div class="mb-3">
            <label class="form-label">Стоимость</label>
            <NumberInput @bind-Value="currentModel.Cost" Step="0.01" />
        </div>
    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Secondary" @onclick="HideModal">Отмена</Button>
        <Button Color="ButtonColor.Primary" @onclick="() => { }">Сохранить</Button>
    </FooterTemplate>
</Modal>

@code {
    private ProductApiModel[]? products;
    private bool isLoading = true;
    private Modal modal = new();
    private bool isEditMode;
    private ProductRequestApiModel currentModel = new();
    private Guid editingId;

    protected override async Task OnInitializedAsync()
    {
    }

    private async Task ShowCreateModal()
    {
        isEditMode = false;
        currentModel = new();
        await modal.ShowAsync();
    }

    private async Task HideModal() => await modal.HideAsync();
}