@page "/documents"
@using DocumentGenerator.Api.Client
@using DocumentGenerator.Web.Services
@using System.Globalization

@inject IDocumentGeneratorApiClient ApiClient
@inject UserState UserState
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ToastService ToastService

<PageTitle>Документы</PageTitle>

<h3>Документы</h3>

@if (isLoading)
{
    <Spinner />
}
else
{
    @if (UserState.IsEditor)
    {
        <Button Color="ButtonColor.Success" @onclick="ShowCreateModal">+ Создать документ</Button>
    }

    @if (documents is null || documents.Length == 0)
    {
        <p class="mt-3">Нет документов</p>
    }
    else
    {
        <table class="table table-hover mt-3">
            <thead>
                <tr>
                    <th>№ документа</th>
                    <th>№ договора</th>
                    <th>Дата</th>
                    <th>Продавец</th>
                    <th>Покупатель</th>
                    <th>Товаров</th>
                    @if (UserState.IsAuthenticated)
                    {
                        <th style="width: 140px;">Действия</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in documents)
                {
                    <tr>
                        <td>@doc.DocumentNumber</td>
                        <td>@doc.ContractNumber</td>
                        <td>@doc.Date.ToString("dd.MM.yyyy")</td>
                        <td>@doc.Seller?.Name</td>
                        <td>@doc.Buyer?.Name</td>
                        <td>@(doc.Products?.Count ?? 0)</td>
                        @if (UserState.IsAuthenticated)
                        {
                            <td>
                                <Dropdown Color="DropdownColor.Secondary">
                                    <DropdownToggleButton>Действия</DropdownToggleButton>
                                    <DropdownMenu>
                                        <DropdownItem @onclick="() => ViewDocument(doc)">
                                            Просмотреть
                                        </DropdownItem>
                                        <DropdownItem @onclick="() => ExportDocument(doc)">
                                            Экспорт в Excel
                                        </DropdownItem>
                                        @if (UserState.IsEditor)
                                        {
                                            <DropdownItem @onclick="() => EditDocument(doc)">
                                                Редактировать
                                            </DropdownItem>
                                        }
                                        @if (UserState.IsAdmin)
                                        {
                                            <DropdownItem @onclick="() => DeleteDocument(doc)">
                                                <span class="text-danger">Удалить</span>
                                            </DropdownItem>
                                        }
                                    </DropdownMenu>
                                </Dropdown>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
}

<Modal @ref="viewModal" Size="ModalSize.Large" Title="@($"Документ №{viewingDocument?.DocumentNumber}")">
    <BodyTemplate>
        @if (viewingDocument is not null)
        {
            <div class="row mb-3">
                <div class="col-md-6 mb-2">
                    <label class="form-label fw-bold">Номер документа</label>
                    <p class="form-control-plaintext">@viewingDocument.DocumentNumber</p>
                </div>
                <div class="col-md-6 mb-2">
                    <label class="form-label fw-bold">Номер договора</label>
                    <p class="form-control-plaintext">@viewingDocument.ContractNumber</p>
                </div>
                <div class="col-md-6 mb-2">
                    <label class="form-label fw-bold">Дата</label>
                    <p class="form-control-plaintext">@viewingDocument.Date.ToString("dd.MM.yyyy")</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6 mb-2">
                    <label class="form-label fw-bold">Продавец</label>
                    <p class="form-control-plaintext">@viewingDocument.Seller?.Name</p>
                    <p class="text-muted small">@viewingDocument.Seller?.Job, ИНН @viewingDocument.Seller?.TaxId</p>
                </div>
                <div class="col-md-6 mb-2">
                    <label class="form-label fw-bold">Покупатель</label>
                    <p class="form-control-plaintext">@viewingDocument.Buyer?.Name</p>
                    <p class="text-muted small">@viewingDocument.Buyer?.Job, ИНН @viewingDocument.Buyer?.TaxId</p>
                </div>
            </div>

            <h5 class="mb-2">Товары</h5>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Наименование</th>
                        <th>Количество</th>
                        <th>Цена</th>
                        <th>Сумма</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var lineIndex = 1;
                        var total = 0.0;
                    }
                    @foreach (var item in viewingDocument.Products ?? [])
                    {
                        var lineTotal = item.Quantity * item.Cost;
                        total += lineTotal;
                        <tr>
                            <td>@lineIndex</td>
                            <td>@item.Product?.Name</td>
                            <td>@item.Quantity</td>
                            <td>@item.Cost.ToString("F2")</td>
                            <td>@lineTotal.ToString("F2")</td>
                        </tr>
                        lineIndex++;
                    }
                </tbody>
                <tfoot>
                    <tr class="fw-bold">
                        <td colspan="4" class="text-end">Итого:</td>
                        <td>@total.ToString("F2")</td>
                    </tr>
                </tfoot>
            </table>
        }
    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Secondary" @onclick="HideViewModal">Закрыть</Button>
    </FooterTemplate>
</Modal>

<Modal @ref="editModal" Size="ModalSize.ExtraLarge" Title="@(isEditMode ? "Редактировать документ" : "Создать документ")">
    <BodyTemplate>
        <div class="row mb-3">
            <div class="col-md-6 mb-2">
                <label class="form-label">Номер документа</label>
                <TextInput @bind-Value="docNumber" Placeholder="Введите номер документа" />
            </div>
            <div class="col-md-6 mb-2">
                <label class="form-label">Номер договора</label>
                <TextInput @bind-Value="contractNumber" Placeholder="Введите номер договора" />
            </div>
            <div class="col-md-6 mb-2">
                <label class="form-label">Дата</label>
                <TextInput @bind-Value="dateString" Placeholder="дд.мм.гггг" />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6 mb-2">
                <label class="form-label">Продавец</label>
                <select class="form-select" @bind="sellerId">
                    <option value="@Guid.Empty">-- Выберите продавца --</option>
                    @foreach (var party in parties ?? [])
                    {
                        <option value="@party.Id">@party.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-6 mb-2">
                <label class="form-label">Покупатель</label>
                <select class="form-select" @bind="buyerId">
                    <option value="@Guid.Empty">-- Выберите покупателя --</option>
                    @foreach (var party in parties ?? [])
                    {
                        <option value="@party.Id">@party.Name</option>
                    }
                </select>
            </div>
        </div>

        <h5 class="mb-2">Товары</h5>

        @if (productLines.Count == 0)
        {
            <p class="text-muted">Нет товаров. Добавьте хотя бы один товар.</p>
        }
        else
        {
            <div style="max-height: 300px; overflow-y: auto;">
                <table class="table table-bordered mb-0">
                    <thead>
                        <tr>
                            <th style="width: 40px;">#</th>
                            <th style="min-width: 200px;">Товар</th>
                            <th style="width: 100px;">Кол-во</th>
                            <th style="width: 130px;">Цена</th>
                            <th style="width: 130px;">Сумма</th>
                            <th style="width: 40px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < productLines.Count; i++)
                        {
                            var line = productLines[i];
                            <tr>
                                <td class="align-middle text-center">@(i + 1)</td>
                                <td>
                                    <select class="form-select" @onchange="(e) => OnProductSelected(line, e)">
                                        <option value="">-- Выберите товар --</option>
                                        @foreach (var p in GetAvailableProducts(line))
                                        {
                                            var isSelected = p.Id == line.ProductId;
                                            <option value="@p.Id" selected="@isSelected">@p.Name</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <input type="number" class="form-control" @bind-Value="line.Quantity"
                                           @bind-Value:event="oninput" min="1" />
                                </td>
                                <td>
                                    <input type="number" class="form-control" @bind-Value="line.Cost"
                                           @bind-Value:event="oninput" min="0" step="0.01" />
                                </td>
                                <td class="align-middle text-end fw-bold">
                                    @line.Amount.ToString("F2")
                                </td>
                                <td class="align-middle text-center">
                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                            @onclick="() => RemoveProductLine(line)" title="Удалить товар">
                                        ✕
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="mt-2 d-flex justify-content-between align-items-center">
            <Button Color="ButtonColor.Primary" @onclick="AddProductLine">+ Добавить товар</Button>
            <strong class="fs-5">Итого: @GetTotal().ToString("F2")</strong>
        </div>
    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Secondary" @onclick="HideEditModal">Отмена</Button>
        <Button Color="ButtonColor.Primary" @onclick="SaveDocumentAsync">Сохранить</Button>
    </FooterTemplate>
</Modal>

@code {
    private DocumentApiModel[]? documents;
    private PartyApiModel[]? parties;
    private ProductApiModel[]? products;
    private bool isLoading = true;

    private Modal viewModal = new();
    private DocumentApiModel? viewingDocument;

    private Modal editModal = new();
    private bool isEditMode;
    private Guid editingId;
    private string docNumber = "";
    private string contractNumber = "";
    private string dateString = DateTime.Now.ToString("dd.MM.yyyy");
    private Guid sellerId;
    private Guid buyerId;
    private List<ProductLine> productLines = new();

    private class ProductLine
    {
        public Guid ProductId { get; set; }
        public string ProductName { get; set; } = "";
        public int Quantity { get; set; } = 1;
        public double Cost { get; set; }
        public double Amount => Quantity * Cost;
    }

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsAuthenticated)
        {
            Navigation.NavigateTo("/");
            return;
        }

        try
        {
            var docsTask = ApiClient.DocumentAllAsync();
            var partiesTask = ApiClient.PartyAllAsync();
            var productsTask = ApiClient.ProductAllAsync();

            await Task.WhenAll(docsTask, partiesTask, productsTask);

            documents = docsTask.Result is not null ? [.. docsTask.Result] : null;
            parties = partiesTask.Result is not null ? [.. partiesTask.Result] : null;
            products = productsTask.Result is not null ? [.. productsTask.Result] : null;
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось загрузить данные"));
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDocumentsAsync()
    {
        try
        {
            var list = await ApiClient.DocumentAllAsync();
            documents = list is not null ? [.. list] : null;
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось загрузить документы"));
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ViewDocument(DocumentApiModel doc)
    {
        try
        {
            viewingDocument = await ApiClient.DocumentGETAsync(doc.Id);
            await viewModal.ShowAsync();
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось загрузить документ"));
        }
    }

    private async Task ShowCreateModal()
    {
        isEditMode = false;
        editingId = Guid.Empty;
        docNumber = "";
        contractNumber = "";
        dateString = DateTime.Now.ToString("dd.MM.yyyy");
        sellerId = Guid.Empty;
        buyerId = Guid.Empty;
        productLines = new();
        await editModal.ShowAsync();
    }

    private async Task EditDocument(DocumentApiModel doc)
    {
        DocumentApiModel fullDoc;
        try
        {
            fullDoc = await ApiClient.DocumentGETAsync(doc.Id);
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось загрузить документ"));
            return;
        }

        isEditMode = true;
        editingId = fullDoc.Id;
        docNumber = fullDoc.DocumentNumber;
        contractNumber = fullDoc.ContractNumber;
        dateString = fullDoc.Date.ToString("dd.MM.yyyy");
        sellerId = fullDoc.Seller?.Id ?? Guid.Empty;
        buyerId = fullDoc.Buyer?.Id ?? Guid.Empty;
        productLines = (fullDoc.Products ?? [])
            .Select(p => new ProductLine
            {
                ProductId = p.Product?.Id ?? Guid.Empty,
                ProductName = p.Product?.Name ?? "",
                Quantity = p.Quantity,
                Cost = p.Cost,
            })
            .ToList();

        await editModal.ShowAsync();
    }

    private async Task SaveDocumentAsync()
    {
        if (string.IsNullOrWhiteSpace(docNumber))
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Введите номер документа"));
            return;
        }
        if (string.IsNullOrWhiteSpace(contractNumber))
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Введите номер договора"));
            return;
        }
        if (sellerId == Guid.Empty)
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Выберите продавца"));
            return;
        }
        if (buyerId == Guid.Empty)
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Выберите покупателя"));
            return;
        }
        if (productLines.Count == 0)
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Добавьте хотя бы один товар"));
            return;
        }
        if (!DateOnly.TryParseExact(dateString, ["dd.MM.yyyy", "yyyy-MM-dd"], CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsedDate))
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Неверный формат даты. Используйте ДД.ММ.ГГГГ"));
            return;
        }

        var request = new DocumentRequestApiModel
        {
            DocumentNumber = docNumber,
            ContractNumber = contractNumber,
            Date = new DateTimeOffset(parsedDate.ToDateTime(TimeOnly.MinValue, DateTimeKind.Utc)),
            SellerId = sellerId,
            BuyerId = buyerId,
            Products = productLines
                .Where(pl => pl.ProductId != Guid.Empty)
                .Select(pl => new DocumentProductRequestApiModel
                {
                    ProductId = pl.ProductId,
                    Quantity = pl.Quantity,
                    Cost = pl.Cost,
                })
                .ToList(),
        };

        if (request.Products.Count == 0)
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Добавьте хотя бы один товар"));
            return;
        }

        try
        {
            if (isEditMode)
            {
                await ApiClient.DocumentPUTAsync(editingId, request);
                ToastService.Notify(new(ToastType.Success, "Успех", "Документ обновлён"));
            }
            else
            {
                await ApiClient.DocumentPOSTAsync(request);
                ToastService.Notify(new(ToastType.Success, "Успех", "Документ создан"));
            }

            await editModal.HideAsync();
            isLoading = true;
            StateHasChanged();
            await LoadDocumentsAsync();
        }
        catch (ApiException ex) when (ex.StatusCode == 409)
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Документ с таким номером и договором уже существует"));
        }
        catch (ApiException ex) when (ex.StatusCode == 422)
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Проверьте правильность заполнения полей"));
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось сохранить документ"));
        }
    }

    private async Task DeleteDocument(DocumentApiModel doc)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Удалить документ №\"{doc.DocumentNumber}\"?");
        if (!confirmed) return;

        try
        {
            await ApiClient.DocumentDELETEAsync(doc.Id);
            ToastService.Notify(new(ToastType.Success, "Успех", "Документ удалён"));
            await LoadDocumentsAsync();
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось удалить документ"));
        }
    }

    private async Task ExportDocument(DocumentApiModel doc)
    {
        try
        {
            var response = await ApiClient.ExportAsync(doc.Id);
            using var ms = new MemoryStream();
            await response.Stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"Акт №{doc.DocumentNumber}.xlsx";
            await JS.InvokeVoidAsync("downloadFile", fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", base64);
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось экспортировать документ"));
        }
    }

    private void AddProductLine()
    {
        if (products is null || products.Length == 0)
        {
            ToastService.Notify(new(ToastType.Warning, "Предупреждение", "Сначала создайте товары в разделе «Товары»"));
            return;
        }
        productLines.Add(new ProductLine());
    }

    private void RemoveProductLine(ProductLine line) => productLines.Remove(line);

    private void OnProductSelected(ProductLine line, ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (string.IsNullOrEmpty(value)) return;

        if (!Guid.TryParse(value, out var productId) || productId == Guid.Empty) return;

        if (productLines.Any(pl => pl != line && pl.ProductId == productId))
        {
            ToastService.Notify(new(ToastType.Warning, "Предупреждение", "Этот товар уже добавлен в документ"));
            return;
        }

        var product = products?.FirstOrDefault(p => p.Id == productId);
        if (product is null) return;

        line.ProductId = product.Id;
        line.ProductName = product.Name;
        line.Cost = product.Cost;
    }

    private IEnumerable<ProductApiModel> GetAvailableProducts(ProductLine currentLine)
    {
        if (products is null) return Enumerable.Empty<ProductApiModel>();

        var selectedIds = productLines
            .Where(pl => pl.ProductId != Guid.Empty && pl.ProductId != currentLine.ProductId)
            .Select(pl => pl.ProductId)
            .ToHashSet();

        return products.Where(p => !selectedIds.Contains(p.Id));
    }

    private double GetTotal() => productLines.Sum(pl => pl.Amount);

    private async Task HideViewModal() => await viewModal.HideAsync();

    private async Task HideEditModal() => await editModal.HideAsync();

    private async Task ReloadDocumentsAsync()
    {
        try
        {
            var list = await ApiClient.DocumentAllAsync();
            documents = list is not null ? [.. list] : null;
        }
        catch
        {
            ToastService.Notify(new(ToastType.Danger, "Ошибка", "Не удалось загрузить документы"));
        }
        finally
        {
            isLoading = false;
        }
    }
}
